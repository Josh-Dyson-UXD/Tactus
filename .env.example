# ── Production / proxy deployment (server/) ─────────────────────────────────
# Read at container runtime by server/index.js, NEVER by the browser build.
# This is the token that matters for the deployed wall panel — see README
# "Deployment" for how to generate and rotate it.
HA_URL=http://10.0.0.40:8123
HA_TOKEN=your-long-lived-access-token

# ── Direct-to-HA dev mode only — do NOT set these for a proxy deployment ───
# VITE_-prefixed vars are inlined into the client JS bundle at build time.
# Setting VITE_HA_TOKEN for a production build defeats the whole point of the
# proxy: the token would ship straight to the browser again. Leave both unset
# unless you're running `npm run dev` against HA directly with no proxy in
# front of it.
# VITE_HA_URL=http://homeassistant.local:8123
# VITE_HA_TOKEN=your-long-lived-access-token
